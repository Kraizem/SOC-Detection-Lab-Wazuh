<!-- 
  Use Case 1 – Network Reconnaissance Detection
  MITRE ATT&CK: T1046 – Network Service Discovery
  Attack Method: Port scanning using Nmap
  Detection: Wazuh custom rule analyzing network logs for scan patterns
-->

<group name="network_recon,mitre_t1046,">

  <!-- Rule 1: Detect generic Nmap scan attempt -->
  <rule id="100001" level="10">
    <if_group>syslog</if_group>
    <match>nmap</match>
    <description>Nmap scan detected – Possible network reconnaissance activity</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>network_scan,recon,</group>
  </rule>

  <!-- Rule 2: Detect SYN stealth scan (-sS) pattern – high port connection rate -->
  <rule id="100002" level="12">
    <if_group>syslog</if_group>
    <match>SYN scan|stealth scan|port scan</match>
    <description>Stealth SYN scan detected – Attacker may be mapping open ports</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>network_scan,recon,attack,</group>
  </rule>

  <!-- Rule 3: Detect full port scan (-p-) – large number of connection attempts -->
  <rule id="100003" level="14">
    <if_group>firewall</if_group>
    <match>REJECT|DROP|DENY</match>
    <same_source_ip />
    <timeframe>60</timeframe>
    <frequency>50</frequency>
    <description>Multiple connection rejections from same source – Possible full port scan (nmap -p-)</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>network_scan,recon,high_frequency,</group>
  </rule>

</group>
