<!-- 
  Use Case 3 – Suspicious Network Activity
  MITRE ATT&CK: T1049 – System Network Connections Discovery
  Activity: Monitoring abnormal outbound network connections
  Detection: Correlation of network logs and process activity through Wazuh
-->

<group name="suspicious_network,mitre_t1049,sysmon,">

  <!-- Rule 1: Sysmon Event ID 3 – Detect outbound connection to uncommon port -->
  <rule id="100020" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.destinationPort" type="pcre2">^(4444|1337|8888|9999|6666|31337)$</field>
    <description>Sysmon: Outbound connection to suspicious port – Possible C2 or enumeration activity (T1049)</description>
    <mitre>
      <id>T1049</id>
    </mitre>
    <group>network_activity,suspicious_port,</group>
  </rule>

  <!-- Rule 2: Unusual process making outbound network connection -->
  <rule id="100021" level="11">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)cmd\.exe|powershell\.exe|wscript\.exe|cscript\.exe</field>
    <field name="win.eventdata.initiated">true</field>
    <description>Sysmon: Shell process initiated outbound network connection – Suspicious activity (T1049)</description>
    <mitre>
      <id>T1049</id>
      <id>T1059</id>
    </mitre>
    <group>network_activity,process_network,</group>
  </rule>

  <!-- Rule 3: High frequency outbound connections from single process -->
  <rule id="100022" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^3$</field>
    <same_field>win.eventdata.image</same_field>
    <timeframe>60</timeframe>
    <frequency>20</frequency>
    <description>Sysmon: High frequency outbound connections from single process – Possible network scanning or beacon (T1049)</description>
    <mitre>
      <id>T1049</id>
      <id>T1046</id>
    </mitre>
    <group>network_activity,high_frequency,</group>
  </rule>

  <!-- Rule 4: Correlated – network activity following recon commands (chained detection) -->
  <rule id="100023" level="15">
    <if_sid>100020,100021,100022</if_sid>
    <if_matched_sid>100010,100011,100012</if_matched_sid>
    <timeframe>300</timeframe>
    <description>CORRELATED: Suspicious network activity detected after recon commands – High confidence attack sequence (T1049 + T1059)</description>
    <mitre>
      <id>T1049</id>
      <id>T1059</id>
    </mitre>
    <group>network_activity,correlated,attack_chain,high_severity,</group>
  </rule>

</group>
